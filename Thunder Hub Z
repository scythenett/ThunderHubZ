-- ============================================================
local function findClosestEgg()
    local closest, closestDist = nil, math.huge
    for obj in pairs(espObjects) do
        if obj and obj.Parent and not skippedEggs[obj] and not isUnderBiomeStructureHolder(obj) then
            local pos = getPos(obj)
            if pos and root and not isTooHighForPathfinding(obj) then
                local dist = (root.Position-pos).Magnitude
                if dist < closestDist then closest=obj; closestDist=dist end
            end
        end
    end
    return closest
end

-- ============================================================
-- RAYCAST-DRIVEN MOVEMENT SYSTEM
-- ============================================================

-- Shared raycast params (exclude local character, rebuilt when char respawns)
local moveRP = RaycastParams.new()
moveRP.FilterType = Enum.RaycastFilterType.Exclude

local function rebuildMoveRP()
    moveRP.FilterDescendantsInstances = {character}
end
