-- ── Sensor functions ──────────────────────────────────────────

-- Returns the Y of the floor directly below pos, or nil if no floor within maxDrop
local function floorY(pos, maxDrop)
    maxDrop = maxDrop or 12
    local hit = workspace:Raycast(pos + Vector3.new(0, 0.5, 0), Vector3.new(0, -(maxDrop + 0.5), 0), moveRP)
    return hit and hit.Position.Y or nil
end

-- Returns how high a wall is at distance dist in direction dir from pos.
-- Shoots rays at multiple heights and returns the highest hit, or 0 if clear.
local function wallHeight(pos, dir, dist)
    local heights = {0.3, 1.2, 2.2, 3.5}
    local maxH = 0
    for _, h in ipairs(heights) do
        local hit = workspace:Raycast(pos + Vector3.new(0, h, 0), dir * dist, moveRP)
        if hit then
            maxH = math.max(maxH, h)
        end
    end
    return maxH
end

-- True if stepping forward dist in dir drops into a hole (no floor within dropTol)
local function isHole(pos, dir, dist, dropTol)
    dropTol = dropTol or 3.5
    local probe = pos + dir * dist + Vector3.new(0, 0.3, 0)
    local curFY = floorY(pos) or pos.Y
    local nextFY = floorY(probe)
    if nextFY == nil then return true end           -- no floor at all
    if curFY - nextFY > dropTol then return true end  -- big drop = hole / cliff
    return false
end

-- Cast a fan of rays in directions around baseDir (horizontal).
-- Returns a steering correction vector to avoid walls and holes.
local function steerSensors(pos, baseDir, speed)
    local flatX, flatZ = baseDir.X, baseDir.Z
    local flatMag = math.sqrt(flatX * flatX + flatZ * flatZ)
    if flatMag < 0.02 then
        return Vector3.new(0, 0, 0)
    end
    flatX, flatZ = flatX / flatMag, flatZ / flatMag

    local angles = {0, math.rad(22), math.rad(-22), math.rad(45), math.rad(-45)}
    local correction = Vector3.new(0, 0, 0)
    local WALL_DIST = 2.8 + speed * 0.08
    local HOLE_DIST = 2.2

    for _, a in ipairs(angles) do
        local cos_a, sin_a = math.cos(a), math.sin(a)
        local probeDir = Vector3.new(
            flatX * cos_a - flatZ * sin_a,
            0,
            flatX * sin_a + flatZ * cos_a
        )
        if probeDir.Magnitude < 0.01 then continue end
        probeDir = probeDir.Unit

        local wh = wallHeight(pos, probeDir, WALL_DIST)
        if wh > 0 and wh < 2.6 then
            -- Climbable step (< 2.6 studs) — just walk into it, humanoid auto-steps
            -- No steering needed, but we'll nudge slightly away if far off-centre
        elseif wh >= 2.6 then
            -- Tall wall — steer away from this direction
            local weight = (a == 0) and 2.0 or 1.0  -- centre ray weighs more
            correction = correction - probeDir * weight
        end

        if isHole(pos, probeDir, HOLE_DIST) then
            -- Hole ahead in this direction — steer away strongly
            local weight = (a == 0) and 3.0 or 1.5
            correction = correction - probeDir * weight
        end
    end

    return correction
end

-- ── Jump decision ─────────────────────────────────────────────
-- True if something blocks movement ahead but horizontal casts from jump height clear
-- (classic ledge: low hit, high clear). Tall vertical faces hit both low and torso rays,
-- so we also scan upward — if any apex-height cast misses or hits farther, try a jump.
local function shouldJump(pos, dir)
    if dir.Magnitude < 0.05 then return false end
    local d = dir.Unit
    local reach = 3.2
    local originLo = pos + Vector3.new(0, 0.5, 0)
    local lo = workspace:Raycast(originLo, d * reach, moveRP)
    if not lo then return false end
    local lowDist = (lo.Position - originLo).Magnitude

    local hi = workspace:Raycast(pos + Vector3.new(0, 5.5, 0), d * reach, moveRP)
    if not hi then return true end

    for _, h in ipairs({3.2, 4.2, 5.2, 6.2, 7.0}) do
        local o = pos + Vector3.new(0, h, 0)
        local mid = workspace:Raycast(o, d * reach, moveRP)
        if not mid then return true end
        if (mid.Position - o).Magnitude > lowDist + 0.35 then return true end
    end
    return false
end

-- ── Core: drive character toward a world position using sensors ──
-- Multi-stage stuck recovery before returning "stuck". Returns "arrived", "stuck", "cancelled".
local function driveToward(targetPos, tolerance, timeout, alive)
    tolerance = tolerance or 3
    timeout   = timeout or 10

    local TICK        = 0.05
    local STALL_WIN   = 1.05
    local STALL_EPS   = 0.65
    local MAX_UNSTUCK = 6

    local deadline     = tick() + timeout
    local stallMark    = tick()
    local stallPos     = root and root.Position or Vector3.new()
    local jumpCD       = 0
    local lastMoveTo   = Vector3.new(0, 0, 0)
    local unstuckChain = 0
    local lastGoalDist = nil

    local function safeMoveTo(pt)
        if not alive() or not root or not humanoid then return end
        pcall(function()
            humanoid:MoveTo(pt)
        end)
    end

    local function runUnstuck(baseDir)
        unstuckChain = unstuckChain + 1
        if unstuckChain > MAX_UNSTUCK then
            return false
        end
        local phase = unstuckChain % 4
        pcall(function()
            humanoid.Jump = true
        end)
        task.wait(0.1)
        if not alive() or not root then return false end
        local bx, bz = baseDir.X, baseDir.Z
        local bm = math.sqrt(bx * bx + bz * bz)
        if bm < 0.05 then
            bx, bz = 1, 0
        else
            bx, bz = bx / bm, bz / bm
        end
        if phase == 1 or phase == 3 then
            local px, pz = -bz, bx
            safeMoveTo(root.Position + Vector3.new(px * 5, 0, pz * 5))
        elseif phase == 2 then
            safeMoveTo(root.Position + Vector3.new(-bx * 4, 0, -bz * 4))
        else
            local ang = math.random() * math.pi * 2
            safeMoveTo(root.Position + Vector3.new(math.cos(ang) * 6, 0, math.sin(ang) * 6))
        end
        task.wait(0.32)
        stallMark = tick()
        stallPos = root.Position
        return true
    end

    while tick() < deadline do
        if not alive() then return "cancelled" end
        if not root or not root.Parent or not humanoid or humanoid.Health <= 0 then return "cancelled" end

        local pos = root.Position
        local toT = targetPos - pos
        local flat = Vector3.new(toT.X, 0, toT.Z)
        local dist = flat.Magnitude

        if dist < tolerance then return "arrived" end

        if lastGoalDist and (lastGoalDist - dist) > 0.18 then
            unstuckChain = math.max(0, unstuckChain - 2)
        end
        lastGoalDist = dist

        local state = humanoid:GetState()
        local inAir = (state == Enum.HumanoidStateType.Jumping or state == Enum.HumanoidStateType.Freefall)

        local baseDir = dist > 0.12 and flat.Unit or Vector3.new(0, 0, -1)

        local moveTarget
        if not inAir then
            local correction = steerSensors(pos, baseDir, humanoid.WalkSpeed)
            local steered = flat + correction * 2.5
            local steerFlat = Vector3.new(steered.X, 0, steered.Z)
            local steerDir = steerFlat.Magnitude > 0.12 and steerFlat.Unit or baseDir

            local proj = pos + steerDir * 8
            local fY = floorY(proj) or pos.Y
            moveTarget = Vector3.new(proj.X, fY, proj.Z)

            jumpCD = math.max(0, jumpCD - TICK)
            -- Rays use baseDir (toward goal). steerDir avoids walls and no longer faces the wall, so shouldJump(steerDir) was always false.
            if jumpCD <= 0 and shouldJump(pos, baseDir) then
                -- Long run toward goal keeps speed; vault uses goal direction, not avoidance steering.
                local vault = pos + baseDir * 16
                local vY = floorY(vault) or pos.Y
                vault = Vector3.new(vault.X, vY, vault.Z)
                safeMoveTo(vault)
                task.wait(0.08)
                if alive() then
                    pcall(function()
                        humanoid:MoveTo(vault)
                    end)
                    pcall(function()
                        humanoid.Jump = true
                    end)
                    task.wait(0.05)
                    pcall(function()
                        local s = humanoid:GetState()
                        if s ~= Enum.HumanoidStateType.Jumping and s ~= Enum.HumanoidStateType.Freefall then
                            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                        end
                    end)
                    jumpCD = 1.75
                    local lt = tick()
                    repeat
                        task.wait(0.03)
                    until humanoid:GetState() == Enum.HumanoidStateType.Freefall or tick() - lt > 0.55
                    local land = tick()
                    repeat
                        task.wait(0.05)
                    until humanoid:GetState() == Enum.HumanoidStateType.Running
                        or humanoid:GetState() == Enum.HumanoidStateType.Landed
                        or tick() - land > 2.6
                    task.wait(0.04)
                end
                continue
            end
        else
            moveTarget = Vector3.new(targetPos.X, pos.Y, targetPos.Z)
        end

        if moveTarget and (moveTarget - lastMoveTo).Magnitude > 0.45 then
            safeMoveTo(moveTarget)
            lastMoveTo = moveTarget
        end

        task.wait(TICK)

        if tick() - stallMark >= STALL_WIN then
            local moved = (root.Position - stallPos).Magnitude
            stallMark = tick()
            stallPos = root.Position
            if moved < STALL_EPS then
                if not runUnstuck(baseDir) then
                    resetStuckTracker()
                    return "stuck"
                end
            else
                unstuckChain = math.max(0, unstuckChain - 1)
            end
        end
    end

    local remaining = (Vector3.new(targetPos.X, root.Position.Y, targetPos.Z) - root.Position).Magnitude
    return remaining < tolerance * 2 and "arrived" or "stuck"
end

-- ── pathfindTo: PathfindingService + micro-driver + goal-progress watchdog ──
local function pathfindTo(target)
    if not target or not target.Parent then
        isPathfinding = false
        return false
    end
    local targetPos = getPos(target)
    if not targetPos or not root then
        isPathfinding = false
        return false
    end

    rebuildMoveRP()

    local groundHit = workspace:Raycast(targetPos + Vector3.new(0, 10, 0), Vector3.new(0, -30, 0), moveRP)
    local groundedTarget = groundHit and groundHit.Position or targetPos

    local function alive()
        if not isPathfinding or targetEgg ~= target then return false end
        if not target or not target.Parent then return false end
        if not character or not character.Parent then return false end
        if not humanoid or humanoid.Health <= 0 then return false end
        if not root or not root.Parent then return false end
        return true
    end

    local function nearTarget()
        local p = getPos(target)
        return p ~= nil and root and (root.Position - p).Magnitude < 7
    end

    local function computePath(from, to)
        local ok = pcall(function()
            path:ComputeAsync(from, to)
        end)
        if not ok or path.Status ~= Enum.PathStatus.Success then return nil end
        local wps = path:GetWaypoints()
        return (wps and #wps > 0) and wps or nil
    end

    local function flatDistToGoal()
        if not root then return 0 end
        local g = groundedTarget
        local p = root.Position
        return Vector3.new(g.X - p.X, 0, g.Z - p.Z).Magnitude
    end

    local totalDeadline = tick() + 95
    local globalStuck = 0
    local MAX_STUCK = 8
    local bestDist = flatDistToGoal()
    local progressAt = tick()

    while tick() < totalDeadline do
        if not alive() then return false end
        if not target or not target.Parent then
            cleanupESP(target)
            return false
        end
        if nearTarget() then
            pressE()
            task.wait(1.5)
            pressE()
            return true
        end

        pcall(checkWater)

        local dNow = flatDistToGoal()
        if dNow < bestDist - 0.12 then
            bestDist = dNow
            progressAt = tick()
            globalStuck = math.max(0, globalStuck - 1)
        elseif tick() - progressAt > 7.5 then
            globalStuck = globalStuck + 1
            setStatus("Goal stalled — macro unstuck " .. globalStuck, Color3.fromRGB(255, 200, 90))
            resetStuckTracker()
            pcall(function()
                humanoid.Jump = true
                local ang = math.random() * math.pi * 2
                humanoid:MoveTo(root.Position + Vector3.new(math.cos(ang) * 7, 0, math.sin(ang) * 7))
            end)
            task.wait(0.55)
            progressAt = tick()
            bestDist = math.min(bestDist, flatDistToGoal())
            if globalStuck >= MAX_STUCK then
                skippedEggs[target] = true
                retryEgg = target
                setStatus("Unreachable — skipping", Color3.fromRGB(220, 80, 80))
                return false
            end
        end

        local waypoints = computePath(root.Position, groundedTarget)

        if not waypoints then
            local result = driveToward(groundedTarget, 7, 12, alive)
            if result == "cancelled" then return false end
            if result == "stuck" then
                globalStuck = globalStuck + 1
                if globalStuck >= MAX_STUCK then
                    skippedEggs[target] = true
                    retryEgg = target
                    setStatus("Unreachable — skipping", Color3.fromRGB(220, 80, 80))
                    return false
                end
                local angle = math.random() * math.pi * 2
                pcall(function()
                    humanoid:MoveTo(root.Position + Vector3.new(math.cos(angle) * 5, 0, math.sin(angle) * 5))
                end)
                task.wait(0.65)
            end
            task.wait(0.05)
            continue
        end

        local recompute = false
        local i = 1
        while i <= #waypoints do
            if not alive() then return false end
            if nearTarget() then
                pressE()
                task.wait(1.5)
                pressE()
                return true
            end

            local wp = waypoints[i]

            if wp.Action == Enum.PathWaypointAction.Jump then
                local nextWp = waypoints[i + 1]
                if nextWp then
                    -- Run toward landing; near jump wp or timeout — then Jump + ChangeState fallback (Jump alone often ignored with MoveTo).
                    pcall(function()
                        humanoid:MoveTo(nextWp.Position)
                    end)
                    local t0 = tick()
                    local run = Vector3.new(nextWp.Position.X - wp.Position.X, 0, nextWp.Position.Z - wp.Position.Z)
                    local runUnit = run.Magnitude > 0.12 and run.Unit or Vector3.new(1, 0, 0)
                    repeat
                        task.wait(0.04)
                        if not alive() then return false end
                        local flat = Vector3.new(wp.Position.X - root.Position.X, 0, wp.Position.Z - root.Position.Z)
                        local aligned = flat.Magnitude <= 5.5
                        local past = flat:Dot(runUnit) <= -0.4
                    until aligned or past or tick() - t0 > 2.8

                    if alive() then
                        pcall(function()
                            humanoid:MoveTo(nextWp.Position)
                        end)
                        pcall(function()
                            humanoid.Jump = true
                        end)
                        task.wait(0.05)
                        pcall(function()
                            local s = humanoid:GetState()
                            if s ~= Enum.HumanoidStateType.Jumping and s ~= Enum.HumanoidStateType.Freefall then
                                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                            end
                        end)
                        local lt = tick()
                        repeat
                            task.wait(0.03)
                        until humanoid:GetState() == Enum.HumanoidStateType.Freefall or tick() - lt > 0.55
                        local land = tick()
                        repeat
                            task.wait(0.05)
                        until humanoid:GetState() == Enum.HumanoidStateType.Running
                            or humanoid:GetState() == Enum.HumanoidStateType.Landed
                            or tick() - land > 3
                        task.wait(0.05)
                    end
                else
                    local r = driveToward(wp.Position, 2.5, 7, alive)
                    if r == "cancelled" then return false end
                    if alive() then
                        pcall(function()
                            humanoid.Jump = true
                        end)
                        task.wait(0.45)
                    end
                end

                i = i + 1
                continue
            end

            local wpDist = (Vector3.new(wp.Position.X, root.Position.Y, wp.Position.Z) - root.Position).Magnitude
            local wpTimeout = math.clamp(wpDist / 5 + 2, 4, 22)

            local result = driveToward(wp.Position, 2.8, wpTimeout, alive)

            if result == "cancelled" then return false end

            if result == "stuck" then
                globalStuck = globalStuck + 1
                if globalStuck >= MAX_STUCK then
                    skippedEggs[target] = true
                    retryEgg = target
                    setStatus("Unreachable — skipping", Color3.fromRGB(220, 80, 80))
                    return false
                end
                recompute = true
                break
            else
                globalStuck = math.max(0, globalStuck - 1)
            end

            i = i + 1
        end

        if not recompute and nearTarget() then
            pressE()
            task.wait(1.5)
            pressE()
            return true
        end

        task.wait(0.04)
    end

    skippedEggs[target] = true
    retryEgg = target
    setStatus("Could not reach egg", Color3.fromRGB(220, 80, 80))
    return false
end

