-- ============================================================
-- ANTI-LAG STATE
-- ============================================================
local lagReductionEnabled  = false
local noTexturesEnabled    = false
local noAurasEnabled       = false
local noShadowsEnabled     = false
local noParticlesEnabled   = false
local no3DEnabled          = false

-- Store originals for restore
local originalTextureIds   = {}
local originalParticles    = {}
local originalShadows      = {}

local function applyNoTextures(enabled)
    if enabled then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Texture") or obj:IsA("Decal") then
                if not originalTextureIds[obj] then
                    originalTextureIds[obj] = obj.Texture
                end
                obj.Texture = ""
            end
        end
    else
        for obj, tex in pairs(originalTextureIds) do
            if obj and obj.Parent then obj.Texture = tex end
        end
        originalTextureIds = {}
    end
end

local function applyNoAuras(enabled)
    local function processObj(obj)
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then
            if enabled then
                if originalParticles[obj] == nil then
                    originalParticles[obj] = obj.Enabled
                end
                obj.Enabled = false
            else
                if originalParticles[obj] ~= nil then
                    obj.Enabled = originalParticles[obj]
                    originalParticles[obj] = nil
                end
            end
        end
    end
    for _, plr in pairs(Players:GetPlayers()) do
        local char = plr.Character
        if char then
            for _, obj in pairs(char:GetDescendants()) do processObj(obj) end
        end
    end
    if not enabled then originalParticles = {} end
end

local function applyNoShadows(enabled)
    if enabled then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") then
                if originalShadows[obj] == nil then
                    originalShadows[obj] = obj.CastShadow
                end
                obj.CastShadow = false
            end
        end
        pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
    else
        for obj, v in pairs(originalShadows) do
            if obj and obj.Parent then obj.CastShadow = v end
        end
        originalShadows = {}
        pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic end)
    end
end

local function applyNoParticles(enabled)
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("ParticleEmitter") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then
            obj.Enabled = not enabled
        end
    end
end

local function applyNo3D(enabled)
    -- Disables 3D rendering by setting the frame rate to minimum and hiding the viewport
    -- We use the Lighting service to toggle ambient occlusion and set quality to lowest
    pcall(function()
        local lighting = game:GetService("Lighting")
        if enabled then
            -- Set all rendering to absolute minimum
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
            -- Disable expensive lighting features
            local ao = lighting:FindFirstChildOfClass("AmbientOcclusion") or lighting:FindFirstChildOfClass("DepthOfField")
            if ao then ao.Enabled = false end
            local bloom = lighting:FindFirstChildOfClass("Bloom")
            if bloom then bloom.Enabled = false end
            local blur = lighting:FindFirstChildOfClass("BlurEffect")
            if blur then blur.Enabled = false end
            local cc = lighting:FindFirstChildOfClass("ColorCorrectionEffect")
            if cc then cc.Enabled = false end
            local sunrays = lighting:FindFirstChildOfClass("SunRaysEffect")
            if sunrays then sunrays.Enabled = false end
            -- Make all BaseParts invisible (effectively disables 3D scene rendering visually)
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") and obj ~= root then
                    obj.LocalTransparencyModifier = 1
                end
            end
        else
            settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
            -- Re-enable lighting effects
            for _, fx in pairs(game:GetService("Lighting"):GetChildren()) do
                if fx:IsA("PostEffect") then
                    pcall(function() fx.Enabled = true end)
                end
            end
            -- Restore all parts
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("BasePart") then
                    obj.LocalTransparencyModifier = 0
                end
            end
        end
    end)
end

local function applyLagReduction(enabled)
    if enabled then
        if noTexturesEnabled  then applyNoTextures(true)  end
        if noAurasEnabled     then applyNoAuras(true)     end
        if noShadowsEnabled   then applyNoShadows(true)   end
        if noParticlesEnabled then applyNoParticles(true) end
        if no3DEnabled        then applyNo3D(true)        end
    else
        applyNoTextures(false)
        applyNoAuras(false)
        applyNoShadows(false)
        applyNoParticles(false)
        applyNo3D(false)
    end
end

