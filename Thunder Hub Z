local function isEggName(name)
    local low = name:lower()
    if BLACKLIST[low] then return false end
    if low:match("^point_egg_%d+$") then return true end
    if low:match("^random_potion_egg") then return true end
    if low:match("egg") then return true end
    return false
end

local function isTooHighForPathfinding(obj)
    if not heightFilterEnabled then return false end
    local pos = getPos(obj)
    return pos ~= nil and pos.Y > MAX_EGG_HEIGHT
end

local function isUnderBiomeStructureHolder(obj)
    local cur = obj
    while cur do
        if cur.Name == "BiomeStructureHolder" then return true end
        cur = cur.Parent
    end
    return false
end

local function resolveEggObject(obj)
    local cur = obj
    while cur and cur ~= workspace and cur ~= game do
        if isEggName(cur.Name) then
            local root2 = cur
            while root2.Parent and root2.Parent ~= workspace do root2 = root2.Parent end
            if root2.Parent == workspace then return root2 end
        end
        cur = cur.Parent
    end
    return nil
end

local function checkAndAdd(obj)
    local eggObj = resolveEggObject(obj)
    if not eggObj then return end
    -- Reject eggs that live inside a BiomeStructureHolder
    local cur = eggObj
    while cur and cur ~= workspace do
        if cur.Name == "BiomeStructureHolder" then return end
        cur = cur.Parent
    end
    if espObjects[eggObj] then return end
    createESP(eggObj)
end

