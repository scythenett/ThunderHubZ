local function makeCalibBtn(parent, y, label, calKey)
    local btn = Instance.new("TextButton")
    btn.Size             = UDim2.new(1,-20, 0, 28)
    btn.Position         = UDim2.new(0,10, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(14,14,22)
