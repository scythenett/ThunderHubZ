-- VIRTUAL CLICK HELPER
-- ============================================================
local function vClick(x, y)
    if not x or not y then return end
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, true,  game, 0)
    task.wait(0.05)
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    task.wait(0.15)
end

local function vType(text)
    for i = 1, #text do
        local c = text:sub(i, i)
        VirtualInputManager:SendKeyEvent(true,  c, false, game)
        task.wait(0.03)
        VirtualInputManager:SendKeyEvent(false, c, false, game)
        task.wait(0.03)
    end
    task.wait(0.2)
end

local function vClear()
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.LeftControl, false, game)
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.A, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.A, false, game)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.LeftControl, false, game)
    VirtualInputManager:SendKeyEvent(true,  Enum.KeyCode.Delete, false, game)
    task.wait(0.05)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Delete, false, game)
    task.wait(0.1)
end

