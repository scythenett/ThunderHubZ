    if input.KeyCode==Enum.KeyCode.G then autoToggleBtn.MouseButton1Click:Fire()
    elseif input.KeyCode==Enum.KeyCode.F then goBtn.MouseButton1Click:Fire()
    elseif input.KeyCode==Enum.KeyCode.H then stopBtn.MouseButton1Click:Fire()
    elseif input.KeyCode==Enum.KeyCode.J then
        print("=== EGG ESP DEBUG ===")
        for obj in pairs(espObjects) do
            local pos=getPos(obj)
            local flag=skippedEggs[obj] and "SKIPPED" or (isTooHighForPathfinding(obj) and "TOO HIGH" or "OK")
            print(string.format("[%s] %s | Y=%.1f",flag,obj.Name,pos and pos.Y or -1))
        end
        print("=== END ===")
    end
end)

-- ============================================================
-- RENDER LOOP
-- ============================================================
RunService.RenderStepped:Connect(function()
    local espOn = espGet()
    for obj, data in pairs(espObjects) do
        local pos = getPos(obj)
        if not pos then
            data.billboard.Enabled = false
        else
            data.billboard.Enabled = espOn
            if espOn then
                local dist = root and (root.Position-pos).Magnitude or 0
                data.label.Text = string.format("%s [%dm]", obj.Name, math.floor(dist))
                if obj==targetEgg then
                    data.label.TextColor3 = Color3.fromRGB(0,255,0)
                elseif skippedEggs[obj] then
                    data.label.TextColor3 = Color3.fromRGB(180,80,80)
                elseif isTooHighForPathfinding(obj) then
                    data.label.TextColor3 = Color3.fromRGB(255,120,30)
                else
                    data.label.TextColor3 = Color3.fromRGB(255,255,0)
                end
            end
        end
    end
end)

-- ============================================================
-- AUTO-COLLECT LOOP
-- ============================================================
task.spawn(function()
    while true do
        task.wait(0.5)
        if autoCollect and not isPathfinding then
            local function tryCollect(egg)
                targetEgg = egg
                isPathfinding = true
                setStatus("Collecting: "..egg.Name, Color3.fromRGB(80,220,120))

                local collected = false
                local ok, err = pcall(function()
                    collected = (pathfindTo(egg) == true)
                end)
                if not ok then warn("[eggscript pathfindTo]", err) end

                isPathfinding = false
                targetEgg = nil
                return collected
            end

            -- Prefer the previously failed egg if it has been re-enabled.
            local eggToTry = nil
            if retryEgg and retryEgg.Parent and not skippedEggs[retryEgg] then
                eggToTry = retryEgg
            else
                eggToTry = findClosestEgg()
            end

            if eggToTry then
                local collected = tryCollect(eggToTry)
                if collected then
                    if retryEgg and retryEgg ~= eggToTry then
                        -- Got the "other" egg; re-enable the red/failed one so we can retry it next.
                        skippedEggs[retryEgg] = nil
                    else
                        -- Retry egg was also successfully collected (or no retry pending).
                        retryEgg = nil
                        skippedEggs[eggToTry] = nil
                    end
                end

                task.wait(collected and 1.0 or 0.5)
                if autoCollect then
                    setStatus("Auto-collecting...", Color3.fromRGB(80,220,120))
                end
            else
                task.wait(2)
            end
        end
    end
end)

