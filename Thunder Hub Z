-- Sidebar needs at least this many pixels of body height to show all 5 buttons
local SIDEBAR_MIN_BODY = BTN_START_Y + #TABS * (BTN_H + BTN_GAP) + 8
local SIDEBAR_MIN_TOTAL = 38 + SIDEBAR_MIN_BODY + 22  -- topbar + body + statusbar

local TAB_HEIGHTS = {
    ESP    = math.max(38 + 290 + 22,       SIDEBAR_MIN_TOTAL),
    Aura   = math.max(38 + (calY+50) + 22, SIDEBAR_MIN_TOTAL),
    Quests = math.max(38 + (qY+50) + 22,   SIDEBAR_MIN_TOTAL),
    Items  = math.max(38 + (iY+50) + 22,   SIDEBAR_MIN_TOTAL),
    Perf   = math.max(38 + 408 + 22,       SIDEBAR_MIN_TOTAL),
}
for k,v in pairs(TAB_HEIGHTS) do
    if v > 560 then TAB_HEIGHTS[k] = 560 end
end

local function switchTab(name)
    activeTab = name
    local col = TAB_COLORS[name]
    for _, tabName in ipairs(TABS) do
        local t = tabBtns[tabName]
        local active = tabName == name
        t.bar.Visible = active
        if active then
            TweenService:Create(t.btn,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(18,22,30)}):Play()
            t.icon.TextColor3 = col
            t.lbl.TextColor3  = col
        else
            TweenService:Create(t.btn,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(14,14,22)}):Play()
            t.icon.TextColor3 = Color3.fromRGB(75, 75, 98)
            t.lbl.TextColor3  = Color3.fromRGB(75, 75, 98)
        end
    end
    for _, pg in pairs(pages) do pg.Visible = false end
    if pages[name] then pages[name].Visible = true end
    -- Update main stroke color to match active tab
    TweenService:Create(mainStroke,TweenInfo.new(0.2),{Color=col}):Play()
    TweenService:Create(main, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
        Size = UDim2.new(0, TOTAL_W, 0, TAB_HEIGHTS[name] or 320)
    }):Play()
end

for _, tabName in ipairs(TABS) do
    tabBtns[tabName].btn.MouseButton1Click:Connect(function()
        switchTab(tabName)
    end)
end

