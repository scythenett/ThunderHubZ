    btn.Text             = ""
    btn.AutoButtonColor  = false
    btn.Parent           = parent
    local bc = Instance.new("UICorner"); bc.CornerRadius = UDim.new(0,7); bc.Parent = btn
    local bs = Instance.new("UIStroke")
    bs.Color = Color3.fromRGB(50,80,200); bs.Thickness = 1; bs.Transparency = 0.5; bs.Parent = btn

    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2.new(1,-10,1,0)
    lbl.Position           = UDim2.new(0,8,0,0)
    lbl.BackgroundTransparency = 1
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.TextSize           = 10
    lbl.Font               = Enum.Font.GothamSemibold
    lbl.Parent             = btn

    local dot = Instance.new("Frame")
    dot.Size             = UDim2.new(0,8,0,8)
    dot.Position         = UDim2.new(1,-14,0.5,-4)
    dot.BackgroundColor3 = CAL[calKey] and Color3.fromRGB(80,220,120) or Color3.fromRGB(60,60,80)
    dot.BorderSizePixel  = 0
    dot.Parent           = btn
    local dc = Instance.new("UICorner"); dc.CornerRadius = UDim.new(1,0); dc.Parent = dot

    local function refresh()
        if CAL[calKey] then
            lbl.Text       = label .. "  (" .. CAL[calKey].x .. "," .. CAL[calKey].y .. ")"
            lbl.TextColor3 = Color3.fromRGB(200,220,200)
            dot.BackgroundColor3 = Color3.fromRGB(80,220,120)
        else
            lbl.Text       = label .. "  [not set]"
            lbl.TextColor3 = Color3.fromRGB(150,150,170)
            dot.BackgroundColor3 = Color3.fromRGB(60,60,80)
        end
    end
    refresh()

    btn.MouseButton1Click:Connect(function()
        calibWaiting = {key = calKey, refresh = refresh}
        lbl.Text       = label .. "  [click target...]"
        lbl.TextColor3 = Color3.fromRGB(255,220,80)
        dot.BackgroundColor3 = Color3.fromRGB(255,220,80)
        bs.Color = Color3.fromRGB(255,220,80)
        setStatus("Click the spot: " .. label, Color3.fromRGB(255,220,80))
    end)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn,TweenInfo.new(0.12),{BackgroundColor3=Color3.fromRGB(18,18,28)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn,TweenInfo.new(0.12),{BackgroundColor3=Color3.fromRGB(14,14,22)}):Play()
    end)

    return btn
end

