-- ============================================================
local function getPos(obj)
    if not obj or not obj.Parent then return nil end
    if obj:IsA("Model") then
        if obj.PrimaryPart then return obj.PrimaryPart.Position end
        local p = obj:FindFirstChildWhichIsA("BasePart", true)
        if p then return p.Position end
        return obj:GetPivot().Position
    elseif obj:IsA("BasePart") then
        return obj.Position
    else
        local p = obj:FindFirstChildWhichIsA("BasePart", true)
        if p then return p.Position end
    end
    return nil
end

local function cleanupESP(obj)
    local data = espObjects[obj]
    if data then
        if data.billboard and data.billboard.Parent then data.billboard:Destroy() end
        espObjects[obj] = nil
        updateCounter()
    end
    if targetEgg == obj then targetEgg = nil; isPathfinding = false end
end

local function createESP(obj)
    if espObjects[obj] then return end
    local billboard = Instance.new("BillboardGui")
    billboard.Name        = "EggESP_Tag"
    billboard.Size        = UDim2.new(0,160,0,30)
    billboard.StudsOffset = Vector3.new(0,3,0)
    billboard.AlwaysOnTop = true
    billboard.Enabled     = false

    local label = Instance.new("TextLabel")
    label.Size                   = UDim2.new(1,0,1,0)
    label.BackgroundTransparency = 1
    label.TextColor3             = Color3.fromRGB(255,255,0)
    label.TextSize               = 14
    label.Font                   = Enum.Font.GothamBold
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3       = Color3.fromRGB(0,0,0)
    label.Text                   = obj.Name
    label.Parent                 = billboard

    local attachTo = obj
    if obj:IsA("Model") then
        attachTo = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart",true)
    elseif not obj:IsA("BasePart") then
        attachTo = obj:FindFirstChildWhichIsA("BasePart",true)
    end
    if not attachTo then billboard:Destroy(); return end

    billboard.Adornee = attachTo
    billboard.Parent  = attachTo
    espObjects[obj]   = {billboard=billboard, label=label}
    updateCounter()

    local conn
    conn = obj.AncestryChanged:Connect(function(_,parent)
        if not parent then conn:Disconnect(); cleanupESP(obj) end
    end)
end

